@model List<(Microsoft.AspNetCore.Identity.IdentityUser user, string role)>

@{
    ViewData["Title"] = "User Management";
}

<div class="card shadow">
 
    <div class="container-fluid">

        <!-- CREATE USER -->
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">➕ Tambah User</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" class="row g-2">

                    <div class="col-md-4">
                        <input name="email" class="form-control" placeholder="Email" required />
                    </div>

                    <div class="col-md-3">
                        <input name="password" type="password" class="form-control" placeholder="Password" required />
                    </div>

                    <div class="col-md-3">
                        <select name="role" class="form-select">
                            <option value="User">User</option>
                            <option value="Admin">Admin</option>
                        </select>
                    </div>

                    <div class="col-md-2">
                        <button class="btn btn-success w-100">Tambah</button>
                    </div>

                </form>
            </div>
        </div>

        <!-- USER LIST -->
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom">
                <h5 class="mb-0">👥 User Management</h5>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-light">
                            <tr>
                                <th>Email</th>
                                <th>Role</th>
                                <th style="width:200px;">Aksi</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.user.Email</td>

                                    <td>
                                        <span class="badge bg-info">@item.role</span>
                                    </td>

                                    <td>
                                        @if (item.user.Email != "admin@warehouse.com")
                                        {
                                            <form asp-action="UpdateRole" method="post" class="d-flex gap-1 mb-1">
                                                <input type="hidden" name="userId" value="@item.user.Id" />

                                                <select name="role" class="form-select form-select-sm">
                                                    <option value="User" selected="@(item.role == "User")">User</option>
                                                    <option value="Admin" selected="@(item.role == "Admin")">Admin</option>
                                                </select>

                                                <button class="btn btn-sm btn-warning">Save</button>
                                            </form>

                                            <form asp-action="Delete"
                                                  asp-route-id="@item.user.Id"
                                                  method="post"
                                                  onsubmit="return confirm('Hapus user ini?')">

                                                <button class="btn btn-sm btn-danger w-100">
                                                    Hapus
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">System Admin</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            </div>
        </div>

    </div>
</div>