@page
@model ForgotPasswordModel

@{
    ViewData["Title"] = "Lupa Password";
}

<style>
    body {
        background-color: #f4f6f9;
    }

    .auth-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
    }

    .auth-card {
        width: 100%;
        max-width: 420px;
        background: #fff;
        border-radius: 16px;
        padding: 30px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .auth-header {
        text-align: center;
        margin-bottom: 25px;
    }

        .auth-header h3 {
            font-weight: 600;
        }

    .form-control {
        border-radius: 10px;
    }

    .btn-auth {
        background: #4f46e5;
        color: #fff;
        border-radius: 10px;
        padding: 12px;
        font-weight: 600;
    }

        .btn-auth:hover {
            background: #4338ca;
        }
</style>

<div class="auth-container">

    <div class="auth-card">

        <div class="auth-header">
            <h3>Lupa Password? 🔑</h3>
            <p class="text-muted small">
                Masukkan email Anda, kami akan kirim link reset password
            </p>
        </div>

        <form method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- EMAIL -->
            <div class="form-floating mb-4">
                <input asp-for="Input.Email" class="form-control" placeholder="Email" />
                <label>Email</label>
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <!-- BUTTON -->
            <button type="submit" class="btn btn-auth w-100 mb-3" id="resetBtn">
                Kirim Link Reset
            </button>

            <div class="text-center small">
                <a asp-page="./Login">← Kembali ke Login</a>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.querySelector("form").addEventListener("submit", function () {
            const btn = document.getElementById("resetBtn");
            btn.innerHTML = "Mengirim...";
            btn.disabled = true;
        });
    </script>
}