@model SmartWarehouse.Models.Product

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card shadow">
                    <div class="card-header bg-primary text-white">
                        <h5>Tambah Produk Baru</h5>
                    </div>
                    <div class="card-body">
                        <form asp-action="Create">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Scan Barcode / Input SKU</label>
                                <div class="input-group">
                                    <input id="SKUInput" name="SKU" class="form-control" placeholder="Scan atau ketik SKU..." required />
                                    <button type="button" class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#scannerModal">
                                        <i class="bi bi-camera"></i> Scan
                                    </button>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Nama Produk</label>
                                <input name="Name" class="form-control" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Jumlah Stok Awal</label>
                                <input name="StockQuantity" type="number" class="form-control" value="0" required />
                            </div>

                            <button type="submit" class="btn btn-success w-100">Simpan Produk</button>
                        </form>
                    </div>
                </div>

                <div class="modal fade" id="scannerModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header bg-dark text-white">
                                <h5 class="modal-title"><i class="bi bi-qr-code-scan"></i> Scan Barang</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" onclick="stopScanner()"></button>
                            </div>
                            <div class="modal-body">
                                <ul class="nav nav-pills nav-fill mb-3" id="scanTab" role="tablist">
                                    <li class="nav-item">
                                        <button class="nav-link active" id="camera-tab" data-bs-toggle="pill" data-bs-target="#camera-pane" type="button" onclick="startCamera()">Kamera</button>
                                    </li>
                                    <li class="nav-item">
                                        <button class="nav-link" id="file-tab" data-bs-toggle="pill" data-bs-target="#file-pane" type="button" onclick="stopScanner()">Upload File</button>
                                    </li>
                                </ul>

                                <div class="tab-content">
                                    <div class="tab-pane fade show active" id="camera-pane">
                                        <div id="reader" style="width: 100%"></div>
                                    </div>

                                    <div class="tab-pane fade text-center p-4" id="file-pane">
                                        <label for="qr-input-file" class="btn btn-outline-primary p-4 border-dashed w-100">
                                            <i class="bi bi-cloud-arrow-up fs-1"></i><br>
                                            Pilih Gambar Barcode
                                        </label>
                                        <input type="file" id="qr-input-file" accept="image/*" class="d-none">
                                        <div id="file-result-name" class="mt-2 small text-muted"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
        <script>
            let html5QrCode;

                        function onScanSuccess(decodedText) {
                // 1. Isi input SKU
                document.getElementById('SKUInput').value = decodedText;

                // 2. OTOMATIS CARI NAMA PRODUK
                fetch(`/Product/GetNameBySKU?sku=${decodedText}`)
                    .then(response => response.json())
                    .then(data => {
                        const nameInput = document.querySelector('input[name="Name"]');

                        if (data.success) {
                            // Jika produk sudah pernah ada, isi namanya otomatis
                            nameInput.value = data.name;
                            Swal.fire({
                                icon: 'info',
                                title: 'Produk Terdeteksi',
                                text: 'Nama produk otomatis terisi.',
                                timer: 1500,
                                showConfirmButton: false
                            });
                        } else {
                            // Jika produk benar-benar baru, kosongkan agar admin isi manual
                            nameInput.value = "";
                            nameInput.placeholder = "Produk baru, silakan beri nama...";
                            nameInput.focus();
                        }
                    });

                // Tutup Modal dan matikan kamera
                stopScanner();
                var modal = bootstrap.Modal.getInstance(document.getElementById('scannerModal'));
                modal.hide();
            }

            // FUNGSI SCAN DARI FILE (UPLOAD)
            document.getElementById('qr-input-file').addEventListener('change', e => {
                if (e.target.files.length == 0) return;

                const imageFile = e.target.files[0];
                document.getElementById('file-result-name').innerText = "Memproses: " + imageFile.name;

                // Inisialisasi scanner jika belum ada
                const fileScanner = new Html5Qrcode("reader");

                fileScanner.scanFile(imageFile, true)
                    .then(decodedText => {
                        onScanSuccess(decodedText);
                    })
                    .catch(err => {
                        Swal.fire('Gagal', 'Barcode tidak terdeteksi dalam gambar ini.', 'error');
                        document.getElementById('file-result-name').innerText = "";
                    });
            });

            // FUNGSI KAMERA
            function startCamera() {
                html5QrCode = new Html5Qrcode("reader");
                html5QrCode.start(
                    { facingMode: "environment" },
                    { fps: 10, qrbox: { width: 250, height: 150 } },
                    onScanSuccess
                ).catch(err => console.error(err));
            }

            function stopScanner() {
                if (html5QrCode && html5QrCode.isScanning) {
                    html5QrCode.stop().catch(err => console.error(err));
                }
            }

            // Reset saat modal dibuka
            document.getElementById('scannerModal').addEventListener('shown.bs.modal', function () {
                // Default buka kamera jika di tab kamera
                if(document.getElementById('camera-tab').classList.contains('active')) {
                    startCamera();
                }
            });
        </script>
    }
}