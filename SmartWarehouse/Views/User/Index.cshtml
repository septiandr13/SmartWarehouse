@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
@{
    ViewData["Title"] = "User Management";
}

<div class="card shadow">
    <div class="card-header bg-info text-white">
        <h5 class="mb-0"><i class="bi bi-people"></i> Daftar Pengguna Sistem</h5>
    </div>
    <div class="card-body">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Username / Email</th>
                    <th>Status</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Email</td>
                        <td><span class="badge bg-success">Aktif</span></td>
                        <td>
                            @if (user.Email != "admin@warehouse.com")
                            {
                                <form asp-action="Delete" asp-route-id="@user.Id" method="post" onsubmit="return confirm('Hapus user ini?')">
                                    <button type="submit" class="btn btn-sm btn-danger">Hapus</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">System Admin</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>