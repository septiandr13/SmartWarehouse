@page
@model LoginModel

@{
    ViewData["Title"] = "Selamat Datang Kembali!";
}

<div class="login-container">
    <div class="login-card">
        <div class="login-brand">
            <div class="brand-content">
                <img src="https://illustrations.popsy.co/amber/shaking-hands.svg" alt="Welcome" class="brand-img" />
                <h2>Halo lagi! 👋</h2>
                <p>Senang melihatmu kembali. Yuk, masuk ke akunmu!</p>
            </div>
        </div>

        <div class="login-form-section">
            <form id="account" method="post">
                <div class="form-header">
                    <h3>Log In</h3>
                    <p class="text-muted">Gunakan akun lokal atau layanan lain</p>
                </div>

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control custom-input" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control custom-input" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check custom-checkbox">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label" asp-for="Input.RememberMe">Ingat saya</label>
                    </div>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="forgot-link">Lupa password?</a>
                </div>

                <button id="login-submit" type="submit" class="btn btn-login w-100">Masuk Sekarang</button>

                <div class="divider">
                    <span>atau masuk dengan</span>
                </div>

                <div class="external-logins mb-4">
                    @{
                        if ((Model.ExternalLogins?.Count ?? 0) == 0)
                        {
                            <p class="text-muted small">Belum ada layanan eksternal.</p>
                        }
                        else
                        {
                            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                                @foreach (var provider in Model.ExternalLogins!)
                                {
                                    <button type="submit" class="btn btn-outline-secondary w-100 mb-2" name="provider" value="@provider.Name">
                                        Login dengan @provider.DisplayName
                                    </button>
                                }
                            </form>
                        }
                    }
                </div>

                <p class="text-center mb-0">
                    Belum punya akun? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="register-link">Daftar di sini</a>
                </p>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}