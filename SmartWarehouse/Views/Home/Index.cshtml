@{
    ViewData["Title"] = "Warehouse Dashboard";
}

<div class="container mt-4">

    <!-- HEADER -->
    <div class="mb-4">
        <h2 class="fw-bold">📊 Smart Warehouse Dashboard</h2>
        <p class="text-muted">Monitoring stok & aktivitas gudang secara real-time</p>
    </div>

    <!-- FILTER PANEL -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">

            <form method="get" class="row g-3 align-items-end">

                <!-- PRODUCT -->
                <div class="col-12 col-md-3">
                    <label class="form-label small">Produk</label>
                    <select name="productId" class="form-select">
                        <option value="">Semua Produk</option>
                        @foreach (var p in ViewBag.Products)
                        {
                            <option value="@p.Id" selected="@(ViewBag.ProductId == p.Id)">
                                @p.Name
                            </option>
                        }
                    </select>
                </div>

                <!-- DATE RANGE -->
                <div class="col-6 col-md-2">
                    <label class="form-label small">Dari</label>
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate" />
                </div>

                <div class="col-6 col-md-2">
                    <label class="form-label small">Sampai</label>
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate" />
                </div>

                <!-- BULAN -->
                <div class="col-6 col-md-2">
                    <label class="form-label small">Bulan</label>
                    <select name="month" class="form-select">
                        <option value="">Semua</option>
                        @for (int i = 1; i <= 12; i++)
                        {
                            <option value="@i" selected="@(ViewBag.Month == i)">
                                @System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)
                            </option>
                        }
                    </select>
                </div>

                <!-- TAHUN -->
                <div class="col-6 col-md-2">
                    <label class="form-label small">Tahun</label>
                    <select name="year" class="form-select">
                        <option value="">Semua</option>
                        @for (int y = DateTime.Now.Year; y >= 2020; y--)
                        {
                            <option value="@y" selected="@(ViewBag.Year == y)">
                                @y
                            </option>
                        }
                    </select>
                </div>

                <!-- BUTTON -->
                <div class="col-12 col-md-1 d-grid">
                    <button class="btn btn-primary">
                        <i class="bi bi-funnel"></i>
                    </button>
                </div>


                <!-- RESET -->
                <div class="col-12 text-end">
                    <a asp-action="Index" class="small text-decoration-none">Reset Filter</a>
                </div>

                <div class="col-12 text-end">
                    <a class="btn btn-success btn-sm"
                       href="@Url.Action("Export", new {
                           productId = ViewBag.ProductId,
                           startDate = ViewBag.StartDate,
                           endDate = ViewBag.EndDate,
                           month = ViewBag.Month,
                           year = ViewBag.Year
                       })">
                        <i class="bi bi-file-earmark-excel"></i> Export Excel
                    </a>
                </div>


            </form>

        </div>
    </div>

    <!-- KPI CARDS -->
    <div class="row g-3 mb-4">

        <div class="col-12 col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted">Total SKU</small>
                        <h3 class="fw-bold">@ViewBag.TotalProducts</h3>
                    </div>
                    <div class="bg-primary text-white rounded-circle p-3">
                        <i class="bi bi-box-seam fs-4"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a asp-controller="Product" asp-action="Index" class="small text-decoration-none">
                        Lihat Produk →
                    </a>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted">Total Item</small>
                        <h3 class="fw-bold">@ViewBag.TotalStock</h3>
                    </div>
                    <div class="bg-success text-white rounded-circle p-3">
                        <i class="bi bi-stack fs-4"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <span class="small text-muted">Kapasitas gudang</span>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card shadow-sm border-0 h-100 @(ViewBag.LowStockCount > 0 ? "border-danger" : "")">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <small class="text-muted">Stok Kritis</small>
                        <h3 class="fw-bold text-danger">@ViewBag.LowStockCount</h3>
                    </div>
                    <div class="bg-danger text-white rounded-circle p-3">
                        <i class="bi bi-exclamation-triangle fs-4"></i>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <span class="small text-danger">Perlu restock segera</span>
                </div>
            </div>
        </div>

    </div>


    <!-- CHART + ACTIVITY -->
    <div class="row g-4">

        <!-- CHART -->
        <div class="col-12 col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0">
                    <h6 class="mb-0 fw-bold">📈 Top 5 Produk (Stok Terbanyak)</h6>
                </div>
                <div class="card-body">
                    <canvas id="inventoryChart" style="height:300px;"></canvas>
                </div>
            </div>
        </div>

        <!-- ACTIVITY -->
        <div class="col-12 col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0">
                    <h6 class="mb-0 fw-bold">🕒 Aktivitas Terbaru</h6>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Waktu</th>
                                <th>Produk</th>
                                <th>Tipe</th>
                                <th>Qty</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var move in ViewBag.RecentMovements)
                            {
                                <tr>
                                    <td>@move.DateOccurred.ToString("HH:mm")</td>
                                    <td class="text-break">@move.Product?.Name</td>
                                    <td>
                                        <span class="badge @(move.Type == "Inbound" ? "bg-success" : "bg-danger")">
                                            @move.Type
                                        </span>
                                    </td>
                                    <td>
                                        <strong>@(move.QuantityChanged > 0 ? "+" : "")@move.QuantityChanged</strong>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>

    </div>

</div>


@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>

        const ctx = document.getElementById('inventoryChart');

        const labels = @Html.Raw(ViewBag.ChartLabels);
        const inboundData = @Html.Raw(ViewBag.InboundData);
        const outboundData = @Html.Raw(ViewBag.OutboundData);

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Inbound',
                        data: inboundData,
                        borderColor: '#198754',
                        backgroundColor: 'rgba(25,135,84,0.2)',
                        tension: 0.3
                    },
                    {
                        label: 'Outbound',
                        data: outboundData,
                        borderColor: '#dc3545',
                        backgroundColor: 'rgba(220,53,69,0.2)',
                        tension: 0.3
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom'
                    }
                }
            }
        });

    </script>
}